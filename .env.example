# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env.

# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://app_user:app_password@localhost:5432/sig_db"

# ── PostgreSQL (usado pelo docker-compose) ────────────────────────────────────
POSTGRES_DB=sig_db
APP_DB_USER=app_user
APP_DB_PASSWORD=TROQUE_AQUI

# ── Portas ────────────────────────────────────────────────────────────────────
DB_PORT=5432
APP_PORT=3001

# ── Docker ────────────────────────────────────────────────────────────────────
POSTGRES_VOLUME_NAME=sig_postgres_data
DOCKER_NETWORK_NAME=sig_network

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Use um segredo forte (mínimo 32 chars) em produção
JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_AQUI
JWT_EXPIRES=8h

# ── Usuário da API (autenticação simples) ─────────────────────────────────────
APP_USERNAME=admin
APP_PASSWORD=TROQUE_AQUI

# ── CORS ──────────────────────────────────────────────────────────────────────
# Em produção, defina o domínio do frontend: https://meuapp.com
CORS_ORIGIN=*
