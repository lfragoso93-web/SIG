# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env.

# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://app_user:app_password@localhost:5432/sig_db"

# ── PostgreSQL (usado pelo docker-compose) ────────────────────────────────────
POSTGRES_DB=sig_db
APP_DB_USER=app_user
APP_DB_PASSWORD=TROQUE_AQUI

# ── Portas ────────────────────────────────────────────────────────────────────
DB_PORT=5432
# API — porta exposta no host (interna sempre 3000)
API_PORT=3000
# Web — porta exposta no host (interna sempre 3001)
WEB_PORT=3001

# ── Docker ────────────────────────────────────────────────────────────────────
POSTGRES_VOLUME_NAME=sig_postgres_data
DOCKER_NETWORK_NAME=sig_network

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Use um segredo forte (mínimo 32 chars) em produção
JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_AQUI
JWT_EXPIRES=8h

# ── Usuário admin inicial (usado apenas pelo seed) ───────────────────────────
# Rodado via: npm run db:seed
# Após o seed, o usuário fica salvo no banco com senha em hash bcrypt.
# Estas variáveis NÃO são lidas em runtime pelo servidor — apenas no seed.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=TROQUE_AQUI

# ── CORS ──────────────────────────────────────────────────────────────────────
# Em produção, defina o domínio do frontend: https://meuapp.com
# Em dev local: http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# URL pública da API acessível pelo browser em dev local
NEXT_PUBLIC_API_URL=http://localhost:3000
# URL interna da API usada pelo container web (server-side)
INTERNAL_API_URL=http://api:3000
