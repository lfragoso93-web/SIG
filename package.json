{
  "name": "sig-api",
  "version": "0.2.0",
  "description": "Sistema de Investimentos — API REST",
  "main": "dist/index.js",
  "scripts": {
    "dev":           "tsx watch src/index.ts",
    "build":         "tsc -p tsconfig.json",
    "start":         "node dist/index.js",
    "db:migrate":    "prisma migrate dev",
    "db:generate":   "prisma generate",
    "db:studio":     "prisma studio",
    "db:seed":       "tsx prisma/seed.ts",
    "test":          "vitest run",
    "test:watch":    "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.5",
    "express":        "^4.21.2",
    "helmet":         "^8.0.0",
    "jsonwebtoken":   "^9.0.2",
    "zod":            "^3.24.1"
  },
  "devDependencies": {
    "@types/cors":         "^2.8.17",
    "@types/express":      "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node":         "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "prisma":              "^6.0.0",
    "tsx":                 "^4.19.2",
    "typescript":          "^5.7.3",
    "vitest":              "^3.0.0"
  }
}
